# ─── Base de datos (Supabase) ───
# Dashboard de Supabase → Project Settings → Database → Connection string.
#
# DATABASE_URL: usa el "Session pooler" (puerto 5432 del host pooler.supabase.com).
# Recomendado para el server FastAPI — soporta prepared statements y pool normal.
#   postgresql+asyncpg://postgres.<ref>:<PASSWORD>@aws-0-<region>.pooler.supabase.com:5432/postgres
#
# Si en vez del pooler usas el "Transaction pooler" (puerto 6543), revisa database.py:
# necesitas NullPool + statement_cache_size=0 (asyncpg no soporta prepared statements ahí).
#
# Local/desarrollo sin Supabase: postgresql+asyncpg://user:password@localhost:5432/classvip
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/classvip

# DATABASE_URL_DIRECT: conexión "Direct connection" (sin pooler, puerto 5432 de db.<ref>.supabase.co).
# La usa SOLO Alembic para correr migraciones. Si la dejas vacía, Alembic usa DATABASE_URL.
DATABASE_URL_DIRECT=

# ─── Security ───
# Genera uno real con: python -c "import secrets; print(secrets.token_hex(32))"
# En producción la app NO arranca si esto sigue en "change-me" (ver config.py).
SECRET_KEY=change-me-to-a-random-64-char-string
ADMIN_EMAIL=admin@classviptransfers.com
ADMIN_PASSWORD_HASH=  # generado con script de hash

# ─── Stripe ───
# Dashboard de Stripe → Developers → API keys / Webhooks
STRIPE_SECRET_KEY=sk_live_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx

# ─── Resend (Email) ───
# Dashboard de Resend → API Keys
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM=ClassVIP Transfers <bookings@classviptransfers.com>
EMAIL_BCC=operations@classviptransfers.com

# ─── Frontend ───
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# ─── Environment ───
# "production" activa validación estricta del .env (ver config.py) — no arranca si faltan secretos reales.
ENVIRONMENT=development
LOG_LEVEL=INFO

# ─── Observabilidad (opcional) ───
# Vacío = desactivado. Se usará a partir de la tarea T12 del PLAN_PRODUCCION.md.
SENTRY_DSN=

# ─── AI (OpenAI) — agente de chat público (ChatWidget.tsx) ───
# Dashboard de OpenAI → API keys. Vacío = el chat responde 400, el resto del sitio sigue funcionando.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_WHISPER_MODEL=whisper-1
OPENAI_TEMPERATURE=0.3
OPENAI_MAX_TOKENS=400
